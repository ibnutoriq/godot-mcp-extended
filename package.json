{
  "name": "godot-mcp-extended",
  "version": "0.4.0",
  "description": "MCP server for the Godot game engine with a full inspect -> edit -> validate -> e2e toolset (60 tools): scene inspection, node editing, signals, scripts, resources, project settings, single-boot batch/build_scene, diagnostics, and automated headless e2e/UAT testing.",
  "keywords": [
    "godot",
    "mcp",
    "ai",
    "claude",
    "cline"
  ],
  "homepage": "https://github.com/ibnutoriq/godot-mcp-extended",
  "bugs": {
    "url": "https://github.com/ibnutoriq/godot-mcp-extended/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ibnutoriq/godot-mcp-extended.git"
  },
  "license": "MIT",
  "author": "Ibnu Toriq <ibnutoriq@gmail.com>",
  "contributors": [
    "Solomon Elias <solomon@sippy.ai> (original godot-mcp)"
  ],
  "type": "module",
  "bin": {
    "godot-mcp": "./build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && node scripts/build.js",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "prepare": "npm run build",
    "test": "npm run build && node test/integration.test.mjs",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "0.6.0",
    "axios": "^1.7.9",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
